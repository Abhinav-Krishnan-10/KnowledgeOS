# ==============================================================================
#                  KNOWLEDGEOS CONFIGURATION VARIABLE TEMPLATE
# ==============================================================================

# Application Environment (development / production)
ENV=development

# Database Configuration
# In docker-compose, postgres hostname is resolved to 'db'
DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledgeos

# LLM Provider Configuration
# Supported options:
# - gemini: Runs Google Gemini API (model: gemini-2.5-flash)
# - openai: Runs OpenAI API (model: gpt-4o)
# - ollama: Runs local offline model (configured via OLLAMA_MODEL)
LLM_PROVIDER=gemini

# Provider API Credentials (Required if using gemini or openai)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Ollama local parameters (Optional, active when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Local Embedding Model configuration (Loaded locally via sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
